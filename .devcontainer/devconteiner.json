{
  "name": "Podexá PosgreSQL",
  "image": "://microsoft.com",
  "features": {
    "ghcr.io/devcontainers/features/postgres:1": {
      "version": "latest"
    }
  },
  "forwardPorts": [5432],
  "settings": {
    "sqltools.connections": []
  }
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "spacelaxy.spacelaxy-darkwaves",
        "ms-vscode.makefile-tools"
      ]
    }
  }
}
